{
    "name": "rubenmartindev/prestashop-module-hook-bus",
    "description": "Hook bus for PrestaShop modules",
    "keywords": ["prestashop", "hooks", "modules"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Rubén Martín",
            "email": "hola@rubenmartin.dev"
        }
    ],
    "require": {
        "php": ">=5.6.0",
        "psr/container": "^1.0"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpunit/phpunit": "^5.7",
        "squizlabs/php_codesniffer": "^3.13"
    },
    "autoload": {
        "psr-4": {
            "RubenMartinDev\\PrestashopModuleHookBus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RubenMartinDev\\PrestashopModuleHookBus\\Tests\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "5.6.0"
        },
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "tests": "phpunit",
        "cs": "phpcs"
    }
}
